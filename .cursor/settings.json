{
    "mcpServers": {
      "taskmaster-ai": {
        "command": "npx",
        "args": ["-y", "--package=task-master-ai", "task-master-ai"],
        "env": {
          "ANTHROPIC_API_KEY": "你的_ANTHROPIC_API_KEY",
          "MODEL": "claude-3-sonnet-20240229",
          "MAX_TOKENS": "64000",
          "TEMPERATURE": "0.2",
          "DEFAULT_SUBTASKS": "5",
          "DEFAULT_PRIORITY": "medium"
        }
      }
    }
  }