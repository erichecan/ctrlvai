{% schema %}
{
  "name": "Promo Banner",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Special Offer"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Limited time offer"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#f4f4f4"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#333333"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    }
  ],
  "presets": [
    {
      "name": "Promo Banner",
      "category": "Promotional"
    }
  ]
}
{% endschema %}

<div class="promo-banner" style="background-color: {{ section.settings.background_color }};">
  {% if section.settings.background_image %}
    <div class="promo-banner__background">
      {{ section.settings.background_image | image_url: width: 2000 | image_tag:
        loading: 'lazy',
        class: 'promo-banner__image',
        alt: section.settings.heading
      }}
    </div>
  {% endif %}
  
  <div class="promo-banner__content" style="text-align: {{ section.settings.text_alignment }}; color: {{ section.settings.text_color }};">
    {% if section.settings.heading != blank %}
      <h2 class="promo-banner__heading">{{ section.settings.heading }}</h2>
    {% endif %}
    
    {% if section.settings.subheading != blank %}
      <p class="promo-banner__subheading">{{ section.settings.subheading }}</p>
    {% endif %}
    
    {% if section.settings.button_label != blank and section.settings.button_link != blank %}
      <a href="{{ section.settings.button_link }}" class="promo-banner__button">
        {{ section.settings.button_label }}
      </a>
    {% endif %}
  </div>
</div>

<style>
.promo-banner {
  position: relative;
  padding: 3rem 1.5rem;
  overflow: hidden;
  min-height: 250px;
  display: flex;
  align-items: center;
  font-family: Arial, sans-serif;
}

.promo-banner__background {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
}

.promo-banner__image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.2s ease;
}

.promo-banner:hover .promo-banner__image {
  transform: scale(1.03);
}

.promo-banner__content {
  position: relative;
  z-index: 2;
  max-width: 800px;
  margin: 0 auto;
  padding: 1.5rem;
  background-color: rgba(255, 255, 255, 0.95);
  border-radius: 4px;
  backdrop-filter: blur(4px);
}

.promo-banner__heading {
  font-size: 2rem;
  margin-bottom: 0.75rem;
  font-weight: 400;
  line-height: 1.2;
  color: #333;
}

.promo-banner__subheading {
  font-size: 1.125rem;
  margin-bottom: 1.5rem;
  line-height: 1.4;
  color: #666;
}

.promo-banner__button {
  display: inline-block;
  padding: 0.75rem 1.5rem;
  background-color: #0066c0;
  color: #fff;
  text-decoration: none;
  border-radius: 3px;
  font-weight: 400;
  font-size: 0.875rem;
  transition: background-color 0.2s ease;
  border: 1px solid transparent;
}

.promo-banner__button:hover {
  background-color: #0055a4;
}

.promo-banner__button:active {
  background-color: #004c94;
}

@media screen and (max-width: 1024px) {
  .promo-banner {
    padding: 2.5rem 1.25rem;
    min-height: 220px;
  }
  
  .promo-banner__content {
    padding: 1.25rem;
  }
  
  .promo-banner__heading {
    font-size: 1.75rem;
  }
  
  .promo-banner__subheading {
    font-size: 1rem;
  }
}

@media screen and (max-width: 768px) {
  .promo-banner {
    padding: 2rem 1rem;
    min-height: 200px;
  }
  
  .promo-banner__content {
    padding: 1rem;
    width: 90%;
  }
  
  .promo-banner__heading {
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
  }
  
  .promo-banner__subheading {
    font-size: 0.9375rem;
    margin-bottom: 1.25rem;
  }
  
  .promo-banner__button {
    padding: 0.625rem 1.25rem;
    font-size: 0.8125rem;
  }
}

@media screen and (max-width: 480px) {
  .promo-banner {
    padding: 1.5rem 0.75rem;
    min-height: 180px;
  }
  
  .promo-banner__content {
    padding: 0.875rem;
    width: 95%;
  }
  
  .promo-banner__heading {
    font-size: 1.25rem;
    margin-bottom: 0.375rem;
  }
  
  .promo-banner__subheading {
    font-size: 0.875rem;
    margin-bottom: 1rem;
  }
  
  .promo-banner__button {
    padding: 0.5rem 1rem;
    font-size: 0.75rem;
    width: 100%;
    text-align: center;
  }
}
</style> 