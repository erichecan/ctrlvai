{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
    {
      "type": "text",
      "id": "left_text",
      "label": "Left Text",
      "default": "TheBayOutlets"
    },
    {
      "type": "url",
      "id": "left_link",
      "label": "Left Link"
    },
    {
      "type": "text",
      "id": "center_text",
      "label": "Center Text",
      "default": "Tennerama"
    },
    {
      "type": "url",
      "id": "center_link",
      "label": "Center Link"
    },
    {
      "type": "text",
      "id": "right_text",
      "label": "Right Text",
      "default": "AuctionEvent"
    },
    {
      "type": "url",
      "id": "right_link",
      "label": "Right Link"
    },
    {
      "type": "color",
      "id": "background",
      "label": "Background Color",
      "default": "#d32f2f"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#fff"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    }
  ],
  "presets": [
    { "name": "Announcement Bar", "category": "Promotional" }
  ]
}
{% endschema %}

<div class="announcement-bar-pixel">
  <span class="announcement-bar-pixel__item left">
    {% if section.settings.left_link != blank %}
      <a href="{{ section.settings.left_link }}" class="announcement-bar-pixel__link" target="_blank" rel="noopener noreferrer">{{ section.settings.left_text }}</a>
    {% else %}
      {{ section.settings.left_text }}
    {% endif %}
  </span>
  <span class="announcement-bar-pixel__divider"></span>
  <span class="announcement-bar-pixel__item center">
    {% if section.settings.center_link != blank %}
      <a href="{{ section.settings.center_link }}" class="announcement-bar-pixel__link" target="_blank" rel="noopener noreferrer">{{ section.settings.center_text }}</a>
    {% else %}
      {{ section.settings.center_text }}
    {% endif %}
  </span>
  <span class="announcement-bar-pixel__divider"></span>
  <span class="announcement-bar-pixel__item right">
    {% if section.settings.right_link != blank %}
      <a href="{{ section.settings.right_link }}" class="announcement-bar-pixel__link" target="_blank" rel="noopener noreferrer">{{ section.settings.right_text }}</a>
    {% else %}
      {{ section.settings.right_text }}
    {% endif %}
  </span>
</div>

<style>
.announcement-bar-pixel {
  width: 100vw;
  background: #ff0000;
  color: #fff;
  font-family: Arial, Helvetica, sans-serif;
  font-size: 11px;
  font-weight: 700;
  height: 32px;
  line-height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  margin: 0;
  box-sizing: border-box;
  letter-spacing: 0.01em;
  overflow-x: auto;
}

.announcement-bar-pixel__item {
  display: inline-block;
  padding: 0 8px;
  white-space: nowrap;
  text-overflow: ellipsis;
  overflow: hidden;
  max-width: 33vw;
  box-sizing: border-box;
}

.announcement-bar-pixel__divider {
  display: inline-block;
  width: 1px;
  height: 16px;
  background: #fff;
  margin: 0 8px;
  vertical-align: middle;
  opacity: 0.8;
}

.announcement-bar-pixel__link {
  color: #fff;
  text-decoration: none;
  font-weight: 700;
  transition: color 0.2s, text-decoration 0.2s;
}
.announcement-bar-pixel__link:hover,
.announcement-bar-pixel__link:focus {
  color: #ffe600;
  text-decoration: underline;
}
.announcement-bar-pixel__link:active {
  color: #ffd700;
  text-decoration: underline;
}

.announcement-bar-pixel__item.left {
  padding-left: 16px;
  text-align: left;
}

.announcement-bar-pixel__item.center {
  text-align: center;
}

.announcement-bar-pixel__item.right {
  padding-right: 16px;
  text-align: right;
}

@media (max-width: 600px) {
  .announcement-bar-pixel {
    font-size: 11px;
    height: 28px;
    line-height: 28px;
    padding: 0 2px;
  }
  .announcement-bar-pixel__item {
    padding: 0 4px;
    max-width: 40vw;
  }
  .announcement-bar-pixel__divider {
    margin: 0 4px;
    height: 12px;
  }
  .announcement-bar-pixel__item.left {
    padding-left: 4px;
  }
  .announcement-bar-pixel__item.right {
    padding-right: 4px;
  }
}
</style> 