{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "text", "id": "copyright", "label": "版权信息", "default": "© 2024 Overstock.com. All rights reserved." }
  ],
  "blocks": [
    {
      "type": "menu",
      "name": "菜单",
      "settings": [
        { "type": "text", "id": "title", "label": "菜单标题", "default": "MY ACCOUNT" },
        { "type": "link_list", "id": "menu", "label": "菜单", "default": "footer-menu" }
      ]
    },
    {
      "type": "menu",
      "name": "菜单",
      "settings": [
        { "type": "text", "id": "title", "label": "菜单标题", "default": "LET US HELP" },
        { "type": "link_list", "id": "menu", "label": "菜单", "default": "footer-help" }
      ]
    },
    {
      "type": "menu",
      "name": "菜单",
      "settings": [
        { "type": "text", "id": "title", "label": "菜单标题", "default": "COMPANY INFORMATION" },
        { "type": "link_list", "id": "menu", "label": "菜单", "default": "footer-company" }
      ]
    }
  ],
  "presets": [
    { "name": "Footer", "category": "Footer" }
  ]
}
{% endschema %}

<footer class="footer">
  <div class="footer__container">
    <div class="footer__menus">
      {% for block in section.blocks %}
        <div class="footer__menu">
          <div class="footer__menu-title">{{ block.settings.title }}</div>
          <ul class="footer__menu-list">
            {% for link in linklists[block.settings.menu].links %}
              <li><a href="{{ link.url }}" class="footer__menu-link">{{ link.title }}</a></li>
            {% endfor %}
          </ul>
        </div>
      {% endfor %}
    </div>
    <div class="footer__social">
      <a href="#" class="footer__social-icon" aria-label="Facebook"><svg width="22" height="22" fill="#fff"><use xlink:href="#icon-facebook"/></svg></a>
      <a href="#" class="footer__social-icon" aria-label="Instagram"><svg width="22" height="22" fill="#fff"><use xlink:href="#icon-instagram"/></svg></a>
      <a href="#" class="footer__social-icon" aria-label="Twitter"><svg width="22" height="22" fill="#fff"><use xlink:href="#icon-twitter"/></svg></a>
      <a href="#" class="footer__social-icon" aria-label="Pinterest"><svg width="22" height="22" fill="#fff"><use xlink:href="#icon-pinterest"/></svg></a>
    </div>
  </div>
  <div class="footer__bottom">
    <div class="footer__copyright">{{ section.settings.copyright }}</div>
  </div>
  <svg style="display:none">
