  </svg>
</footer>

<style>
.footer {
  background: #222;
  color: #fff;
  font-family: Arial, sans-serif;
  padding-top: 2.2rem;
  border-top: 4px solid #d32f2f;
}
.footer__container {
  max-width: 1200px;
  margin: 0 auto;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 2rem;
  padding: 0 2vw;
}
.footer__menus {
  display: flex;
  gap: 3rem;
  flex: 1 1 0;
}
.footer__menu {
  min-width: 140px;
}
.footer__menu-title {
  font-size: 1rem;
  font-weight: 700;
  margin-bottom: 0.7rem;
  color: #fff;
}
.footer__menu-list {
  list-style: none;
  padding: 0;
  margin: 0;
}
.footer__menu-link {
  color: #fff;
  text-decoration: none;
  font-size: 0.95rem;
  line-height: 2;
  transition: color 0.2s;
}
.footer__menu-link:hover {
  color: #ffe600;
}
.footer__social {
  display: flex;
  gap: 1.2rem;
  align-items: center;
}
.footer__social-icon svg {
  width: 22px;
  height: 22px;
  fill: #fff;
  transition: fill 0.2s;
}
.footer__social-icon:hover svg {
  fill: #ffe600;
}
.footer__bottom {
  border-top: 1px solid #444;
  margin-top: 2rem;
  padding: 1.2rem 2vw 0.7rem 2vw;
  text-align: center;
  font-size: 0.95rem;
  color: #aaa;
}
.footer__copyright {
  color: #aaa;
}
@media (max-width: 900px) {
  .footer__container {
    flex-direction: column;
    gap: 1.2rem;
    align-items: stretch;
  }
  .footer__menus {
    flex-direction: column;
    gap: 1.2rem;
  }
}
@media (max-width: 600px) {
  .footer {
    padding-top: 1rem;
  }
  .footer__container {
    padding: 0 1vw;
  }
  .footer__bottom {
    padding: 0.7rem 1vw 0.5rem 1vw;
    font-size: 0.85rem;
  }
}
</style> 