{% schema %}
{
  "name": "Promo Triple",
  "settings": [
    { "type": "header", "content": "三栏促销区" }
  ],
  "blocks": [
    {
      "type": "promo",
      "name": "促销项",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "图片" },
        { "type": "text", "id": "discount", "label": "折扣", "default": "up to 60% off" },
        { "type": "text", "id": "title", "label": "标题", "default": "designer shoes" },
        { "type": "url", "id": "link", "label": "按钮链接" }
      ]
    }
  ],
  "max_blocks": 3,
  "presets": [
    { "name": "Promo Triple", "category": "Promotion" }
  ]
}
{% endschema %}

<div class="promo-triple">
  {% for block in section.blocks %}
    <div class="promo-triple__item">
      <div class="promo-triple__img">
        {% if block.settings.image %}
          {{ block.settings.image | image_url: width: 300 | image_tag: loading: 'lazy', alt: block.settings.title }}
        {% endif %}
      </div>
      <div class="promo-triple__discount-badge">
        {{ block.settings.discount }}
      </div>
      <div class="promo-triple__title">{{ block.settings.title }}</div>
      <a href="{{ block.settings.link }}" class="promo-triple__button">Shop Now</a>
    </div>
  {% endfor %}
</div>

<style>
.promo-triple {
  display: flex;
  justify-content: center;
  align-items: stretch;
  gap: 2vw;
  background: #fff;
  padding: 2.2rem 0 2.2rem 0;
  border-bottom: 1px solid #e5e5e5;
  font-family: Arial, sans-serif;
}
.promo-triple__item {
  flex: 1 1 0;
  background: #fafafa;
  border-radius: 0.5rem;
  box-shadow: 0 2px 8px rgba(0,0,0,0.04);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 1.2rem 1rem 1.5rem 1rem;
  position: relative;
  min-width: 0;
}
.promo-triple__img img {
  width: 120px;
  height: 120px;
  object-fit: contain;
  margin-bottom: 1.2rem;
}
.promo-triple__discount-badge {
  position: absolute;
  top: 1.2rem;
  left: 1.2rem;
  background: #d32f2f;
  color: #fff;
  border-radius: 50%;
  font-size: 1rem;
  font-weight: 700;
  padding: 0.7rem 1.1rem;
  box-shadow: 0 2px 8px rgba(0,0,0,0.08);
}
.promo-triple__title {
  font-size: 1.1rem;
  font-weight: 700;
  color: #222;
  margin: 2.2rem 0 1.2rem 0;
  text-align: center;
  text-transform: lowercase;
}
.promo-triple__button {
  display: inline-block;
  background: #d32f2f;
  color: #fff;
  font-size: 1rem;
  font-weight: 700;
  border-radius: 2px;
  padding: 0.7rem 2rem;
  text-decoration: none;
  margin-top: auto;
  transition: background 0.2s;
}
.promo-triple__button:hover {
  background: #b71c1c;
}
@media (max-width: 900px) {
  .promo-triple {
    flex-direction: column;
    gap: 1.2rem;
    padding: 1.2rem 0;
  }
  .promo-triple__item {
    flex-direction: row;
    align-items: center;
    justify-content: flex-start;
    gap: 1.2rem;
    padding: 1rem;
  }
  .promo-triple__img img {
    margin-bottom: 0;
  }
  .promo-triple__title {
    margin: 0 0 0.5rem 0;
  }
}
@media (max-width: 600px) {
  .promo-triple__item {
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    padding: 0.7rem;
  }
  .promo-triple__img img {
    width: 80px;
    height: 80px;
  }
  .promo-triple__discount-badge {
    font-size: 0.8rem;
    padding: 0.5rem 0.7rem;
    top: 0.7rem;
    left: 0.7rem;
  }
}
</style> 